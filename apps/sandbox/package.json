{
  "name": "@astryxdesign/sandbox",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:deps": "pnpm -F @astryxdesign/theme-neutral build && pnpm -F @astryxdesign/theme-matcha build && pnpm -F @astryxdesign/theme-stone build && pnpm -F @astryxdesign/theme-gothic build && pnpm -F @astryxdesign/theme-chocolate build && pnpm -F @astryxdesign/theme-y2k build && pnpm -F @astryxdesign/theme-butter build",
    "generate:changelog": "node scripts/generate-changelog.js",
    "generate:cli": "node scripts/generate-cli-registry.mjs",
    "generate": "node ../../scripts/sync-templates.js && pnpm generate:changelog && pnpm generate:cli && node scripts/generate-foundation-docs.mjs",
    "dev": "pnpm generate && (node ../../scripts/sync-templates.js --watch & next dev)",
    "build": "pnpm generate && next build",
    "start": "next start",
    "postinstall": "astryx init --features agents"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@stylexjs/stylex": "^0.18.3",
    "@astryxdesign/cli": "*",
    "@astryxdesign/core": "*",
    "@astryxdesign/lab": "*",
    "@astryxdesign/theme-neutral": "*",
    "@astryxdesign/theme-matcha": "*",
    "next": "^15.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "@astryxdesign/theme-stone": "*",
    "@astryxdesign/theme-gothic": "*",
    "@astryxdesign/theme-chocolate": "*",
    "@astryxdesign/theme-y2k": "*",
    "@astryxdesign/theme-butter": "*"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@stylexjs/babel-plugin": "^0.19.0",
    "@stylexjs/postcss-plugin": "^0.19.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "commander": "^12.1.0",
    "typescript": "^6.0.3",
    "@astryxdesign/build": "*"
  }
}